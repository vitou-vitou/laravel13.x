{
  "mcpServers": {
    "aikido": {
      "command": "npx",
      "args": ["-y", "@aikidosec/mcp"],
      "env": {
        "AIKIDO_API_KEY": "YOUR_AIKIDO_API_KEY"
      }
    },
    "prompts.chat": {
      "url": "https://prompts.chat/api/mcp",
      "headers": {
        "PROMPTS_API_KEY": "YOUR_PROMPTS_CHAT_API_KEY"
      }
    },
    "superhuman-mail": {
      "url": "https://mcp.mail.superhuman.com/mcp",
      "headers": {}
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--caps=devtools"]
    },
    "@21st-dev/magic": {
      "command": "npx",
      "args": ["-y", "@21st-dev/magic@latest"],
      "env": {
        "API_KEY": "YOUR_21ST_DEV_API_KEY"
      }
    },
    "browsermcp": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@browsermcp/mcp@latest"],
      "env": {
        "CHROME_PATH": "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"
      }
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "YOUR_CONTEXT7_API_KEY"
      }
    }
  }
}
