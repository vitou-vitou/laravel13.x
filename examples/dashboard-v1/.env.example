APP_NAME="Analytics Dashboard"
APP_ENV=local
# Generate locally with: php artisan key:generate
APP_KEY=
APP_DEBUG=true
APP_URL=http://dashboard-v1.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Reverb credentials — generate your own; never commit real values.
# Local: any random strings work. Prod: set in the deploy env (Coolify), not here.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ngrok static dev domain for OAuth (claim once: https://dashboard.ngrok.com/domains)
# Then: ./scripts/sync-ngrok-oauth-env.sh --domain YOUR-NAME.ngrok-free.dev
# Or: /admin → Development → Tunnels → create profile → Activate
NGROK_DEV_DOMAIN=

# Filament tunnel profiles (local dev only)
TUNNEL_ADMIN_ENABLED=true

# Filament /admin/login — pre-fill seeded admin credentials (local only)
FILAMENT_DEV_LOGIN_PREFILL=true
FILAMENT_DEV_LOGIN_EMAIL=test@example.com
FILAMENT_DEV_LOGIN_PASSWORD=password

# Google OAuth (optional — BOTH client_id AND client_secret required for SSO buttons on login/register)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Desktop OAuth for gws Gmail CLI (separate from Web SSO above — fixes redirect_uri_mismatch)
GWS_GOOGLE_CLIENT_ID=
GWS_GOOGLE_CLIENT_SECRET=

# Microsoft 365 / Entra ID OAuth (optional — enables "Continue with Microsoft" on login)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI="${APP_URL}/auth/microsoft/callback"
MICROSOFT_TENANT_ID=common

# GitHub OAuth (optional — BOTH client_id AND client_secret required for SSO button on login/register)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# For ngrok OAuth: run sync-ngrok-oauth-env.sh after NGROK_DEV_DOMAIN is set (keep APP_URL on .test)
GITHUB_REDIRECT_URI="${APP_URL}/auth/github/callback"
