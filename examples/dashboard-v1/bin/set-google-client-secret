#!/usr/bin/env bash
# Paste Google OAuth client secret into examples/dashboard-v1/.env (one-time after Create client / Add secret).
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
ENV_FILE="$ROOT/.env"

if [[ ! -f "$ENV_FILE" ]]; then
  echo "Missing $ENV_FILE" >&2
  exit 1
fi

echo "Paste your Google OAuth client secret (starts with GOCSPX-), then press Enter:"
read -r -s SECRET
echo

if [[ -z "${SECRET// /}" ]]; then
  echo "Empty secret — cancelled." >&2
  exit 1
fi

if [[ ! "$SECRET" =~ ^GOCSPX- ]]; then
  echo "Warning: secret usually starts with GOCSPX- — continuing anyway."
fi

if grep -q '^GOOGLE_CLIENT_SECRET=' "$ENV_FILE"; then
  sed -i "s|^GOOGLE_CLIENT_SECRET=.*|GOOGLE_CLIENT_SECRET=$SECRET|" "$ENV_FILE"
else
  echo "GOOGLE_CLIENT_SECRET=$SECRET" >> "$ENV_FILE"
fi

export PATH="/d/laravel13.x/bin:$PATH"
(cd "$ROOT" && php artisan config:clear)

echo "Updated GOOGLE_CLIENT_SECRET in .env and cleared config cache."

REPO_ROOT="$(cd "$ROOT/../.." && pwd)"
if [[ -x "$REPO_ROOT/bin/gws-sync-from-dashboard-env" ]]; then
  if "$REPO_ROOT/bin/gws-sync-from-dashboard-env" 2>/dev/null; then
    echo "Also synced gws Gmail config ($REPO_ROOT/bin/gws-sync-from-dashboard-env)."
  else
    echo "Tip: set GOOGLE_CLIENT_ID in .env, then run $REPO_ROOT/bin/gws-sync-from-dashboard-env for Gmail/TikTok."
  fi
fi
