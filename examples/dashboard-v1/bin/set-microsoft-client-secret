#!/usr/bin/env bash
# Paste Microsoft Entra client secret into examples/dashboard-v1/.env.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
ENV_FILE="$ROOT/.env"

if [[ ! -f "$ENV_FILE" ]]; then
  echo "Missing $ENV_FILE" >&2
  exit 1
fi

echo "Paste your Microsoft Entra client secret, then press Enter:"
read -r -s SECRET
echo

if [[ -z "${SECRET// /}" ]]; then
  echo "Empty secret — cancelled." >&2
  exit 1
fi

if grep -q '^MICROSOFT_CLIENT_SECRET=' "$ENV_FILE"; then
  sed -i "s|^MICROSOFT_CLIENT_SECRET=.*|MICROSOFT_CLIENT_SECRET=$SECRET|" "$ENV_FILE"
else
  echo "MICROSOFT_CLIENT_SECRET=$SECRET" >> "$ENV_FILE"
fi

export PATH="/d/laravel13.x/bin:$PATH"
(cd "$ROOT" && php artisan config:clear)

echo "Updated MICROSOFT_CLIENT_SECRET in .env and cleared config cache."
