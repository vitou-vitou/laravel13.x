#!/usr/bin/env bash
# Copy Google OAuth Desktop client JSON into gws config (one-time manual download from Cloud Console).
set -euo pipefail

GWS_DIR="${GWS_CONFIG_DIR:-$HOME/.config/gws}"
DEST="$GWS_DIR/client_secret.json"

usage() {
  echo "Usage: gws-set-client-secret <path-to-client_secret.json>"
  echo "       gws-set-client-secret   # prompts for file path"
  exit 1
}

SRC="${1:-}"
if [[ -z "$SRC" ]]; then
  echo "Path to downloaded OAuth client JSON (Desktop app):"
  read -r SRC
fi

[[ -n "$SRC" ]] || usage
[[ -f "$SRC" ]] || { echo "File not found: $SRC" >&2; exit 1; }

if ! grep -q '"installed"' "$SRC" && ! grep -q '"web"' "$SRC"; then
  echo "Warning: file may not be a Google OAuth client JSON — copying anyway."
fi

mkdir -p "$GWS_DIR"
cp "$SRC" "$DEST"
chmod 600 "$DEST" 2>/dev/null || true

echo "Saved: $DEST"
echo "Next (manual, opens browser):"
echo "  gws auth login --services gmail --readonly"
