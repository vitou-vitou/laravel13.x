{
  "permissions": {
    "allow": [
      "Bash(Select-String -i filament)",
      "Bash(cmd *)",
      "Bash(php artisan *)",
      "Bash(php *)",
      "PowerShell(Get-ChildItem \"D:\\\\laravel13.x\\\\examples\\\\jwt\" -Force | ForEach-Object { $_.FullName })",
